# ─────────────────────────────────────────────────────────────────────────────

# Groq API key — used by the AI Concierge (Aria) chatbot.
# Get a free key at: https://console.groq.com/keys
# Free tier: 30 req/min · 500,000 tokens/day · no credit card required.
VITE_GROQ_API_KEY=your_groq_api_key_here
